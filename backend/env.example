# Backend environment variables are loaded from the repository root .env file.
# Keep this file as a pointer for older setup instructions.
#
# Use ../.env.example as the current template:
#   cp ../.env.example ../.env
#
# Required backend variables include:
#   DB_HOST
#   DB_PORT
#   DB_USERNAME
#   DB_PASSWORD
#   DB_NAME
#   DB_SSL
#   DB_CA_CERT_PATH or DB_CA_CERT
#   JWT_SECRET
#   BACKEND_JWT_SECRET
#   BACKEND_PORT
