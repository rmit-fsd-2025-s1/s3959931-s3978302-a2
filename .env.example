# Copy this file to .env at the repository root and fill in real values.
# Do not commit .env or any .pem file.

# Environment
NODE_ENV=development

# MySQL database
DB_HOST=your-aiven-host
DB_PORT=your-aiven-port
DB_USERNAME=avnadmin
DB_PASSWORD=your-aiven-password
DB_NAME=defaultdb
DB_SSL=true

# Local certificate file path. Use forward slashes on Windows.
DB_CA_CERT_PATH=E:/GitHub/s3959931-s3978302-a2/aiven-ca.pem

# Alternative for hosted platforms that cannot use secret files.
# DB_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Backend auth secrets. Generate unique long random values for each.
JWT_SECRET=replace-with-long-random-string
BACKEND_JWT_SECRET=replace-with-long-random-string
ADMIN_JWT_SECRET=replace-with-long-random-string
ADMIN_SESSION_SECRET=replace-with-long-random-string

# Demo admin account. Do not use admin/admin for a real production app.
ADMIN_EMAIL=admin
ADMIN_PASSWORD=admin

# Local backend ports
BACKEND_PORT=5000
ADMIN_BACKEND_PORT=4002

# Local frontend endpoints.
# Next.js apps do not automatically read this root file when run inside frontend folders.
# Copy these into frontend/.env.local and admin-frontend/.env.local if you need local overrides,
# and add the hosted values in each Vercel project.
NEXT_PUBLIC_API_ENDPOINT=http://localhost:5000/api
NEXT_PUBLIC_ADMIN_GRAPHQL_ENDPOINT=http://localhost:4002/graphql
NEXT_PUBLIC_ADMIN_WS_ENDPOINT=ws://localhost:4002/graphql

# Deployed frontend URLs for admin-backend CORS. Set these on Render after Vercel deploys.
FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001
